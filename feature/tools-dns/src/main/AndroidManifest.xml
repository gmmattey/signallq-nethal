<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Exigida por ConnectivityManager (checagem de conectividade antes de consultar o
         resolvedor DNS público) — mesma permissão já declarada em :app, mas cada módulo declara
         as permissões que o próprio código usa (mescladas no manifest final). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Consulta HTTP DNS-over-HTTPS contra resolvedor público (Cloudflare). -->
    <uses-permission android:name="android.permission.INTERNET" />

</manifest>
